{
  "name": "surf",
  "version": "1.0.0",
  "author": "SURF team",
  "homepage": "http://zkiiito.github.io/SURF",
  "description": "SURF is a threaded instant messaging application, like Google Wave used to be.",
  "repository": {
    "type": "git",
    "url": "git@github.com:zkiiito/SURF.git"
  },
  "type": "module",
  "exports": "./code/dist/SurfServer.js",
  "license": "GPL-3.0",
  "dependencies": {
    "@types/multer": "^2.1.0",
    "body-parser": "^1.20.5",
    "connect-redis": "^7.1.1",
    "content-type": "^2.0.0",
    "cookie": "^1.1.1",
    "cookie-parser": "^1.4.7",
    "cookie-signature": "^1.2.2",
    "cors": "^2.8.6",
    "errorhandler": "^1.5.2",
    "express": "^4.22.2",
    "express-session": "^1.19.0",
    "got": "^15.0.5",
    "iconv-lite": "^0.7.2",
    "metascraper": "^5.50.3",
    "metascraper-description": "^5.50.1",
    "metascraper-image": "^5.50.1",
    "metascraper-title": "^5.50.1",
    "mongoose": "^8.24.0",
    "multer": "^2.1.1",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "passport-local": "^1.0.0",
    "redis": "^5.12.1",
    "socket.io": "^4.8.3"
  },
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "build": "tsc -p code/tsconfig.json",
    "start": "node Surf.js",
    "dev": "tsc -p code/tsconfig.json --watch",
    "dev:server": "concurrently -k -n tsc,node -c blue,green \"tsc -p code/tsconfig.json --watch\" \"TESTMODE=1 nodemon --watch code/dist --ext js Surf.js\"",
    "dev:react": "npm --prefix client-react run build -- --watch",
    "dev:all": "concurrently -k -n srv,react -c blue,magenta \"npm:dev:server\" \"npm:dev:react\"",
    "test": "vitest run --config code/vitest.config.ts",
    "test:watch": "vitest --config code/vitest.config.ts",
    "test:e2e": "cypress run"
  },
  "devDependencies": {
    "@types/content-type": "^2.0.0",
    "@types/cookie": "^1.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/cookie-signature": "^1.1.2",
    "@types/cors": "^2.8.19",
    "@types/errorhandler": "^1.5.3",
    "@types/express": "^4.17.25",
    "@types/express-session": "^1.19.0",
    "@types/node": "^24.0.0",
    "@types/passport": "^1.0.17",
    "@types/passport-google-oauth20": "^2.0.17",
    "@types/passport-local": "^1.0.38",
    "concurrently": "^9.2.1",
    "cypress": "^15.15.0",
    "eslint": "^10.4.0",
    "nodemon": "^3.1.14",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  },
  "nodemonConfig": {
    "ignore": [
      "client/*",
      "cypress/*"
    ]
  },
  "eslintIgnore": [
    "client/js/jquery/*.js",
    "cypress/*",
    "*.min.js"
  ]
}
