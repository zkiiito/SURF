{
  "name": "surf",
  "version": "1.0.0",
  "author": "SURF team",
  "homepage": "http://zkiiito.github.io/SURF",
  "description": "SURF is a threaded instant messaging application, like Google Wave used to be.",
  "repository": {
    "type": "git",
    "url": "git@github.com:zkiiito/SURF.git"
  },
  "type": "module",
  "exports": "./code/dist/SurfServer.js",
  "license": "GPL-3.0",
  "dependencies": {
    "body-parser": "^1.20.4",
    "connect-redis": "^7.1.1",
    "content-type": "^1.0.5",
    "cookie": "^1.0.0",
    "cookie-parser": "^1.4.7",
    "cookie-signature": "^1.2.1",
    "cors": "^2.8.5",
    "errorhandler": "^1.5.1",
    "express": "^4.22.1",
    "express-session": "^1.18.2",
    "got": "^14.4.2",
    "iconv-lite": "^0.6.3",
    "metascraper": "^5.45.23",
    "metascraper-description": "^5.45.22",
    "metascraper-image": "^5.45.22",
    "metascraper-title": "^5.45.22",
    "mongoose": "^8.9.5",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "passport-local": "^1.0.0",
    "redis": "^4.7.0",
    "socket.io": "^4.8.0"
  },
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "build": "tsc -p code/tsconfig.json",
    "start": "npm run build && node Surf.js",
    "dev": "tsc -p code/tsconfig.json --watch",
    "test": "vitest run --config code/vitest.config.ts",
    "test:watch": "vitest --config code/vitest.config.ts",
    "test:e2e": "cypress run"
  },
  "devDependencies": {
    "@types/content-type": "^1.1.9",
    "@types/cookie": "^0.6.0",
    "@types/cookie-parser": "^1.4.7",
    "@types/cookie-signature": "^1.1.2",
    "@types/cors": "^2.8.17",
    "@types/errorhandler": "^1.5.3",
    "@types/express": "^4.17.21",
    "@types/express-session": "^1.18.0",
    "@types/node": "^20.11.0",
    "@types/passport": "^1.0.16",
    "@types/passport-google-oauth20": "^2.0.16",
    "@types/passport-local": "^1.0.38",
    "cypress": "^13.15.0",
    "eslint": "^8.57.1",
    "nodemon": "^3.1.7",
    "typescript": "^5.3.3",
    "vitest": "^1.2.0"
  },
  "nodemonConfig": {
    "ignore": [
      "client/*",
      "cypress/*"
    ]
  },
  "eslintIgnore": [
    "client/js/jquery/*.js",
    "cypress/*",
    "*.min.js"
  ]
}
